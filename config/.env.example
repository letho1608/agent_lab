# Pupy-NextGen Environment Configuration
# Copy this file to .env and fill in actual values (do not commit .env)

# Server Configuration
PUPI_SERVER_HOST=127.0.0.1
PUPI_SERVER_PORT=5000

# Gist: kho lưu IPv6:port (server cập nhật qua API, client GET raw URL)
# Copy thành .env và điền giá trị thật (không commit .env)

# Raw URL Gist (client dùng GET; server dùng để lấy gist_id + filename)
# Ví dụ: https://gist.githubusercontent.com/USER/GIST_ID/raw/REV/c2.txt
# GIST_RAW_URL=https://gist.githubusercontent.com/USER/GIST_ID/raw/REV/c2.txt
GIST_RAW_URL=

# Token GitHub (scope gist) – server dùng để PATCH nội dung Gist
GIST_TOKEN=
